generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ExposureSnapshot {
  id           Int              @id @default(autoincrement())
  dateKey      String           @unique @db.VarChar(8)
  snapshotDate DateTime         @unique @db.Date
  sourceFile   String           @db.VarChar(255)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  records      ExposureRecord[]
  dailyAgg     ExposureDailyAgg?

  @@index([snapshotDate])
}

model ExposureRecord {
  id           BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  snapshotId   Int
  snapshot     ExposureSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  snapshotDate DateTime         @db.Date
  ip           String           @db.VarChar(45)
  country      String           @default("Unknown") @db.VarChar(128)
  countryZh    String           @default("未知") @db.VarChar(128)
  province     String           @default("未知") @db.VarChar(128)
  region       String           @default("Unknown") @db.VarChar(191)
  city         String           @default("Unknown") @db.VarChar(128)
  asn          String           @default("AS0") @db.VarChar(32)
  isp          String           @default("Unknown ISP") @db.VarChar(191)
  host         String           @default("-") @db.VarChar(128)
  service      String           @default("18789 / OpenClaw") @db.VarChar(128)
  serviceDesc  String           @default("OpenClaw service") @db.VarChar(191)
  operator     String           @default("Unknown Operator") @db.VarChar(64)
  status       String           @default("在线监测") @db.VarChar(64)
  scope        String           @default("境外暴露") @db.VarChar(64)
  version      String           @default("unknown") @db.VarChar(64)
  risk         String           @default("待补充") @db.VarChar(64)
  lastSeen     DateTime         @db.Date
  createdAt    DateTime         @default(now())

  @@unique([snapshotId, ip])
  @@index([snapshotId])
  @@index([snapshotDate])
  @@index([ip])
  @@index([ip, snapshotDate])
  @@index([country])
  @@index([scope])
  @@index([version])
  @@index([operator])
}

model ExposureDailyAgg {
  snapshotDate              DateTime          @id @db.Date
  snapshotId                Int?              @unique
  snapshot                  ExposureSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  exposedCount              Int
  domesticCount             Int               @default(0)
  overseasCount             Int               @default(0)
  newDistinctIpCount        Int               @default(0)
  cumulativeDistinctIpCount Int               @default(0)
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  @@index([snapshotDate])
}

model ExposureVersionDailyAgg {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  snapshotDate DateTime @db.Date
  version      String   @db.VarChar(64)
  count        Int
  createdAt    DateTime @default(now())

  @@unique([snapshotDate, version])
  @@index([snapshotDate])
  @@index([version])
}

model OpenclawRiskSnapshot {
  id                    Int                 @id @default(autoincrement())
  snapshotKey           String              @unique @db.VarChar(32)
  triggerSource         String              @default("scheduled") @db.VarChar(32)
  status                String              @default("completed") @db.VarChar(32)
  latestStableTag       String?             @db.VarChar(64)
  latestStableVersion   String?             @db.VarChar(64)
  latestStableUrl       String?             @db.VarChar(255)
  latestStablePublishedAt DateTime?
  totalIssues           Int                 @default(0)
  githubAdvisories      Int                 @default(0)
  nvdCves               Int                 @default(0)
  officialAdvisoryCount Int                 @default(0)
  cveRecordCount        Int                 @default(0)
  conferencePaperCount  Int                 @default(0)
  preprintCount         Int                 @default(0)
  researchCount         Int                 @default(0)
  newsCount             Int                 @default(0)
  criticalCount         Int                 @default(0)
  highRiskCount         Int                 @default(0)
  fixedCount            Int                 @default(0)
  unfixedCount          Int                 @default(0)
  unknownCount          Int                 @default(0)
  fixProgressPercent    Int                 @default(0)
  sourceMeta            Json
  cacheDir              String?             @db.VarChar(255)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  issues                OpenclawRiskIssue[]

  @@index([createdAt])
  @@index([status, createdAt])
}

model OpenclawRiskIssue {
  id                  BigInt               @id @default(autoincrement()) @db.UnsignedBigInt
  snapshotId          Int
  snapshot            OpenclawRiskSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  canonicalId         String               @db.VarChar(128)
  issueId             String               @db.VarChar(128)
  title               String               @db.VarChar(255)
  summary             String               @db.Text
  description         String               @db.LongText
  sourcePrimary       String               @db.VarChar(32)
  sourceType          String               @default("official_advisory") @db.VarChar(32)
  sourceSearch        String               @db.VarChar(64)
  sourceLabels        Json
  sources             Json
  githubIds           Json
  cveIds              Json
  projectScope        String               @default("agent") @db.VarChar(32)
  venue               String?              @db.VarChar(128)
  authors             Json
  severity            String               @db.VarChar(32)
  score               Float?
  cvssVector          String?              @db.VarChar(255)
  cwes                Json
  affectedRange       String?              @db.Text
  fixedVersion        String?              @db.VarChar(64)
  latestStableVersion String?              @db.VarChar(64)
  fixStatus           String               @db.VarChar(32)
  fixLabel            String               @db.VarChar(32)
  fixReason           String               @db.Text
  issueUrl            String?              @db.VarChar(255)
  repoUrl             String?              @db.VarChar(255)
  referenceUrls       Json
  tags                Json
  status              String               @default("new") @db.VarChar(32)
  relevanceScore      Float? 
  publishedAt         DateTime?
  sourceUpdatedAt     DateTime?
  rawData             Json
  createdAt           DateTime             @default(now())

  @@unique([snapshotId, canonicalId])
  @@index([snapshotId])
  @@index([canonicalId])
  @@index([issueId])
  @@index([severity])
  @@index([fixStatus])
  @@index([sourcePrimary])
  @@index([sourceType])
  @@index([projectScope])
  @@index([venue])
  @@index([status])
  @@index([publishedAt])
}

model SecurityResearchSnapshot {
  id                   Int                   @id @default(autoincrement())
  snapshotKey          String                @unique @db.VarChar(32)
  triggerSource        String                @default("scheduled") @db.VarChar(32)
  status               String                @default("completed") @db.VarChar(32)
  totalPapers          Int                   @default(0)
  conferencePaperCount Int                   @default(0)
  preprintCount        Int                   @default(0)
  openclawCount        Int                   @default(0)
  clawCount            Int                   @default(0)
  skillCount           Int                   @default(0)
  agentCount           Int                   @default(0)
  pluginCount          Int                   @default(0)
  sourceMeta           Json
  cacheDir             String?               @db.VarChar(255)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  papers               SecurityResearchPaper[]

  @@index([createdAt])
  @@index([status, createdAt])
}

model SecurityResearchPaper {
  id                BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  snapshotId        Int
  snapshot          SecurityResearchSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  canonicalId       String                   @db.VarChar(191)
  title             String                   @db.VarChar(500)
  normalizedTitle   String                   @db.VarChar(500)
  sourceType        String                   @db.VarChar(32)
  projectScope      String                   @db.VarChar(32)
  venue             String                   @db.VarChar(128)
  sourcePrimary     String                   @db.VarChar(32)
  sourceSearch      String                   @db.VarChar(128)
  abstractOrSummary String                   @db.LongText
  tags              Json
  sourceUrl         String?                  @db.VarChar(255)
  authors           Json
  externalIds       Json
  relevanceScore    Float                    @default(0)
  isTopVenue        Boolean                  @default(false)
  publishedAt       DateTime?
  status            String                   @default("active") @db.VarChar(32)
  rawData           Json
  createdAt         DateTime                 @default(now())

  @@unique([snapshotId, canonicalId])
  @@index([snapshotId])
  @@index([canonicalId])
  @@index([normalizedTitle])
  @@index([sourceType])
  @@index([projectScope])
  @@index([venue])
  @@index([sourcePrimary])
  @@index([isTopVenue])
  @@index([publishedAt])
  @@index([relevanceScore])
}
